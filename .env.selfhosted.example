# NodeWarden Self-Hosted Configuration
# Copy this file to .env and fill in your values

# Required: JWT secret for token signing (at least 32 characters)
JWT_SECRET=your-secure-jwt-secret-at-least-32-characters-long

# Optional: TOTP secret for server-side TOTP
# TOTP_SECRET=your-totp-secret

# Database path (default: ./data/nodewarden.db)
DATABASE_PATH=./data/nodewarden.db

# Storage path for attachments (default: ./data/attachments)
STORAGE_PATH=./data/attachments

# Server port (default: 3000)
PORT=3000

# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Optional: Frontend static files path (for serving the web app)
# FRONTEND_PATH=./dist
